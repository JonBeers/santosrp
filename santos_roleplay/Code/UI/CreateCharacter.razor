@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

<root>
	
	<div class="nav anim-slide-left anim-delay-5">
		<div class="button" @ref="navIdentity">IDENTITY</div>
		<div class="button" @ref="navAppearance">APPEARANCE</div>
	</div> 

	<div class="panel">
		@switch (currentScreen)
		{
			case Screen.Identity:
			<div class="identity">

			@if ( isError )
			{
				@foreach ( var error in errorList )
				{
					
					<span class="error-msg anim-slide-down anim-delay-2">@error</span>
				}
			}

			<SantosTextEntry Title="First Name:" Placeholder="John" MinLength="@(2)" MaxLength="@(10)" @ref="FirstNameEntry" />
			<SantosTextEntry Title="Last Name:" Placeholder="Doe" MinLength="@(2)" MaxLength="@(10)" @ref="LastNameEntry" />
			<SantosDropDown Title="Gender" Options="@GenderOptions" Value="Male" ValueChanged="@OnGenderChanged" @ref="GenderDropdown"/>
			<SantosNumEntry Title="Age:" Placeholder="100" MinLength="@(1)" MaxLength="@(3)"  @ref="AgeEntry" />

			<button @ref="NextButton" class="next-btn anim-slide-left anim-delay-5" @onclick="@SaveCharacter">
				<img src="images/check-solid.png" />
			</button>

			</div>
			break;

			case Screen.Appearance:
				// For now we will just finish creating the character.
				Game.ActiveScene.LoadFromFile("scenes/menu.scene");
			break;
		}
	</div>

</root>

@code
{

    private Screen currentScreen = Screen.Identity;
    public enum Screen
    {
        Identity,
        Appearance,
        Skills,
        Shop,
    }

    [Property] public SkinnedModelRenderer skinnedModelRenderer {get; set;}
    private List<PlayerData> characters = new();
    private string selectedGender = "male";
    private SantosTextEntry FirstNameEntry;
    private SantosTextEntry LastNameEntry;
    private SantosNumEntry AgeEntry {get; set;}
    private SantosDropDown GenderDropdown; // separate ref variable
    private List<Option> GenderOptions = new List<Option>
    {
        new Option( "Male", "male" ),
        new Option( "Female", "female" ),
    };

    private Panel navIdentity;
    private Panel navAppearance;
	private Panel NextButton;
	private List<string> errorList = new();
	private bool isError => errorList.Count > 0;
	

	protected override void OnTreeBuilt()
	{	
		navIdentity.SetClass("active", currentScreen == Screen.Identity);
		navAppearance.SetClass("active", currentScreen == Screen.Appearance);
	}

	private void OnGenderChanged(string value)
	{
		selectedGender = value;


		if (selectedGender == "male") skinnedModelRenderer.Model = Model.Load("models/citizen_human/citizen_human_male.vmdl");
		else if (selectedGender == "female") skinnedModelRenderer.Model = Model.Load("models/citizen_human/citizen_human_female.vmdl");
		Log.Info($"Gender selected: {selectedGender}");
	}

	protected override void OnAwake()
	{
		Mouse.Visibility = MouseVisibility.Visible;
		characters = PlayerData.Load(Game.SteamId) ?? new();
	}

	private async void SaveCharacter()
	{
		errorList.Clear();

		if ( string.IsNullOrWhiteSpace( FirstNameEntry.Text ) || string.IsNullOrWhiteSpace( LastNameEntry.Text ) || selectedGender == null )
			errorList.Add( "Missing field/fields." );

		if ( FirstNameEntry.Text != null && FirstNameEntry.Text.Any( char.IsDigit ) || 
			LastNameEntry.Text != null && LastNameEntry.Text.Any( char.IsDigit ) )
			errorList.Add( "Character name cannot contain numbers." );

		if ( float.TryParse( AgeEntry.Value, out float age ) )
		{
			if ( age < 18f ) errorList.Add( "Minimum age is 18." );
			if ( age > 100f ) errorList.Add( "Maximum age is 100." );
		}

		if ( errorList.Count > 0 ) return;

		// No errors, save the character
		characters.Add( new PlayerData
		{
			FirstName = FirstNameEntry.Text,
			LastName = LastNameEntry.Text,
			Gender = selectedGender,
			Age = float.Parse( AgeEntry.Value )
		});

		PlayerData.Save( characters, Game.SteamId );
		currentScreen = Screen.Appearance;
	}

}